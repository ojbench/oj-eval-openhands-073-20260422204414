v0x56023c571180_0 .net "rst_in", 0 0, v0x56023c571820_0;  1 drivers
E_0x56023c558c80 .event posedge, v0x56023c51f6f0_0;
    .scope S_0x56023c51f490;
T_0 ;
    %wait E_0x56023c558c80;
    %load/vec4 v0x56023c571180_0;
    %flag_set/vec4 8;
    %jmp/0xz  T_0.0, 8;
    %pushi/vec4 0, 0, 32;
    %assign/vec4 v0x56023c570b70_0, 0;
    %jmp T_0.1;
T_0.0 ;
    %load/vec4 v0x56023c5710c0_0;
    %flag_set/vec4 8;
    %jmp/0xz  T_0.2, 8;
    %load/vec4 v0x56023c570b70_0;
    %addi 1, 0, 32;
    %assign/vec4 v0x56023c570b70_0, 0;
T_0.2 ;
T_0.1 ;
    %jmp T_0;
    .thread T_0;
    .scope S_0x56023c55b150;
T_1 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x56023c571340_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x56023c571820_0, 0, 1;
