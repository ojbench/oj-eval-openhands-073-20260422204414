    .port_info 2 /INPUT 1 "rdy_in";
    .port_info 3 /INPUT 8 "mem_din";
    .port_info 4 /OUTPUT 8 "mem_dout";
    .port_info 5 /OUTPUT 32 "mem_a";
    .port_info 6 /OUTPUT 1 "mem_wr";
    .port_info 7 /OUTPUT 32 "dbgreg_dout";
L_0x56023c5718f0 .functor BUFZ 32, v0x56023c570b70_0, C4<00000000000000000000000000000000>, C4<00000000000000000000000000000000>, C4<00000000000000000000000000000000>;
v0x56023c51f6f0_0 .net "clk_in", 0 0, v0x56023c571340_0;  1 drivers
v0x56023c570b70_0 .var "dbg", 31 0;
v0x56023c570c50_0 .net "dbgreg_dout", 31 0, L_0x56023c5718f0;  alias, 1 drivers
v0x56023c570d10_0 .net "mem_a", 31 0, L_0x7fa937f370a8;  alias, 1 drivers
v0x56023c570df0_0 .net "mem_din", 7 0, v0x56023c571540_0;  1 drivers
v0x56023c570f20_0 .net "mem_dout", 7 0, L_0x7fa937f37060;  alias, 1 drivers
