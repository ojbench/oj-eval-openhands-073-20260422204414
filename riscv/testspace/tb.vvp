    %store/vec4 v0x56023c571750_0, 0, 1;
    %pushi/vec4 0, 0, 8;
    %store/vec4 v0x56023c571540_0, 0, 8;
    %end;
    .thread T_1, $init;
    .scope S_0x56023c55b150;
T_2 ;
    %delay 5000, 0;
    %load/vec4 v0x56023c571340_0;
    %inv;
    %store/vec4 v0x56023c571340_0, 0, 1;
    %jmp T_2;
    .thread T_2;
    .scope S_0x56023c55b150;
T_3 ;
    %vpi_call/w 3 28 "$display", "[TB] Starting simulation..." {0 0 0};
    %delay 20000, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x56023c571820_0, 0, 1;
    %delay 100000, 0;
    %vpi_call/w 3 31 "$display", "[TB] dbgreg_dout=%0d", v0x56023c571400_0 {0 0 0};
    %vpi_call/w 3 32 "$display", "[TB] PASS" {0 0 0};
    %vpi_call/w 3 33 "$finish" {0 0 0};
